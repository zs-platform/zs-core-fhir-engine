          "loinc": "67788-6",
          "options": [
            { 
              "value": "alert", 
              "label": { 
                "en": "Alert", 
                "bn": "সচেতন", 
                "my": "သတိချင်း" 
              },
              "snomed": "248220006"
            },
            { 
              "value": "verbal", 
              "label": { 
                "en": "Verbal Response", 
                "bn": "মৌখিক সাড়া", 
                "my": "စကားချင်း" 
              },
              "snomed": "248234009"
            },
            { 
              "value": "pain", 
              "label": { 
                "en": "Pain Response", 
                "bn": "ব্যথা সাড়া", 
                "my": "နာကျင်ခံစာပြီး" 
              },
              "snomed": "248236006"
            },
            { 
              "value": "unresponsive", 
              "label": { 
                "en": "Unresponsive", 
                "bn": "সাড়া নেই", 
                "my": "မတုံ့မရှိ" 
              },
              "snomed": "419474004"
            }
          ]
        },
        {
          "fieldId": "additional_notes",
          "label": { 
            "en": "Additional Clinical Notes", 
            "bn": "অতিরিক্ত ক্লিনিকাল নোট", 
            "my": "အခြားတိုင်းဆရားမှုတ်မ်းတင်သူမှတ်တမ်း" 
          },
          "type": "textarea",
          "required": false,
          "fhirPath": "Observation.component[code=clinical-notes].valueString",
          "validation": {
            "maxLength": 2000,
            "errorMessage": {
              "en": "Notes cannot exceed 2000 characters",
              "bn": "নোট ২০০০ অক্ষরের বেশি হতে পারে না"
            }
          }
        }
      ]
    }
  ],
  "validationRules": [
    {
      "ruleId": "bp_consistency",
      "description": {
        "en": "Validate blood pressure consistency",
        "bn": "রক্তচাপের সামঞ্জস্যতা যাচাই"
      },
      "condition": {
        "logicalOperator": "and",
        "conditions": [
          { "fieldId": "blood_pressure_systolic", "operator": "exists", "value": true },
          { "fieldId": "blood_pressure_diastolic", "operator": "exists", "value": true }
        ]
      },
      "expression": "blood_pressure_systolic > blood_pressure_diastolic",
      "errorMessage": {
        "en": "Systolic pressure must be greater than diastolic pressure",
        "bn": "সিস্টোলিক চাপ ডায়াস্টোলিক চাপের চেয়ে বড় হতে হবে"
      },
      "severity": "error"
    },
    {
      "ruleId": "vitals_complete",
      "description": {
        "en": "Ensure core vitals are recorded",
        "bn": "মূল অত্যাবরিক চিহ্নিত্সা রেকর্ড করা হয়েছে তা নিশ্চিত করুন"
      },
      "condition": {
        "logicalOperator": "or",
        "conditions": [
          { "fieldId": "blood_pressure_systolic", "operator": "exists", "value": true },
          { "fieldId": "heart_rate", "operator": "exists", "value": true },
          { "fieldId": "temperature", "operator": "exists", "value": true },
          { "fieldId": "respiratory_rate", "operator": "exists", "value": true }
        ]
      },
      "expression": "blood_pressure_systolic || heart_rate || temperature || respiratory_rate",
      "errorMessage": {
        "en": "At least one core vital sign must be recorded",
        "bn": "অন্তত একটি মূল অত্যাবরিক চিহ্নিত্সা রেকর্ড করতে হবে"
      },
      "severity": "warning"
    }
  ],
  "workflows": [
    {
      "workflowId": "vitals_assessment_complete",
      "name": {
        "en": "Complete Vitals Assessment",
        "bn": "অত্যাবরিক চিহ্নিত্সা মূল্যায়ন সম্পূর্ণ"
      },
      "trigger": "onSubmit",
      "actions": [
        {
          "action": "create_observation_panel",
          "target": "fhir-server",
          "parameters": {
            "resource": "Observation",
            "profile": "zs-vitals-panel",
            "category": "vital-signs"
          }
        },
        {
          "action": "check_clinical_alerts",
          "target": "clinical-decision-support",
          "parameters": {
            "alert_types": ["vital-signs", "pain", "consciousness"]
          }
        },
        {
          "action": "update_encounter",
          "target": "emr-system",
          "parameters": {
            "add_vitals_to_encounter": true
          }
        }
      ]
    }
  ]
}
