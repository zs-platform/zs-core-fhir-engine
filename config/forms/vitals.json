{
  "$schema": "https://forms.zarishsphere.com/schema/v2/form.json",
  "zsFormVersion": "2.0.0",
  "formId": "zs-form-vitals-v2",
  "formName": "Vital Signs Assessment",
  "formNameTranslations": {
    "en": "Vital Signs Assessment",
    "bn": "অত্যাবরিক চিহ্নিত্সা মূল্যায়ন",
    "my": "အရေးအဖျားစစစ်ဆိုင်း",
    "ur": "ضروری نشانیاں کا جائزہ",
    "hi": "महत्वपूर्ण संकेत जांच",
    "th": "การประเมินสัญญาณชีพิกาล"
  },
  "fhirResource": "Observation",
  "fhirProfile": "https://fhir.zarishsphere.com/StructureDefinition/zs-vitals-panel",
  "fhirVersion": "5.0.0",
  "clinical_domain": "vitals",
  "program": "primary-care",
  "languages": ["en", "bn", "my", "ur", "hi", "th"],
  "version": "2.0.0",
  "status": "active",
  "lastUpdated": "2026-04-03T12:00:00Z",
  "securityClassification": "restricted",
  "privacySettings": {
    "requiresExplicitConsent": true,
    "dataRetentionPeriod": "P10Y",
    "anonymizationRules": ["patient_identifiers"],
    "gdprCompliance": {
      "dataController": "ZarishSphere Health Authority",
      "legalBasis": "vital-interests",
      "dataSubjectRights": ["access", "rectification", "restriction"]
    }
  },
  "sections": [
    {
      "sectionId": "sec-patient-context",
      "label": { 
        "en": "Patient Context", 
        "bn": "রোগী প্রেক্ষিত", 
        "my": "လူနာအကြေအနေ" 
      },
      "description": {
        "en": "Patient identification and encounter context",
        "bn": "রোগী শনাক্ত ও সাক্ষাতের প্রেক্ষিত"
      },
      "fields": [
        {
          "fieldId": "patient_identifier",
          "label": { 
            "en": "Patient ID", 
            "bn": "রোগী আইডি", 
            "my": "လူနာမှတ်ပုံတင်" 
          },
          "type": "text",
          "required": true,
          "fhirPath": "Observation.subject.reference",
          "dataEntry": {
            "autoComplete": true,
            "lookupTable": "patients"
          }
        },
        {
          "fieldId": "encounter_id",
          "label": { 
            "en": "Encounter ID", 
            "bn": "সাক্ষাতের আইডি", 
            "my": "တွေ့ဆုံးမှတ်ပုံတင်" 
          },
          "type": "text",
          "required": true,
          "fhirPath": "Observation.encounter.reference"
        },
        {
          "fieldId": "vitals_date_time",
          "label": { 
            "en": "Date & Time of Measurement", 
            "bn": "পরিমাপের তারিখ ও সময়", 
            "my": "တိုင်းတိုင်းရက်စွဲ" 
          },
          "type": "datetime",
          "required": true,
          "fhirPath": "Observation.effectiveDateTime",
          "defaultValue": "${currentDateTime}",
          "validation": {
            "customRules": [
              {
                "rule": "not_future_datetime",
                "message": {
                  "en": "Measurement time cannot be in the future",
                  "bn": "পরিমাপের সময় ভবিষ্যতে হতে পারে না"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "sectionId": "sec-basic-vitals",
      "label": { 
        "en": "Basic Vital Signs", 
        "bn": "মৌলিক অত্যাবরিক চিহ্নিত্সা", 
        "my": "အခြေခံအရေးအဖျားစစစ်ဆိုင်း" 
      },
      "description": {
        "en": "Core vital signs measurements",
        "bn": "মূল অত্যাবরিক চিহ্নিত্সা পরিমাপ"
      },
      "fields": [
        {
          "fieldId": "blood_pressure_systolic",
          "label": { 
            "en": "Blood Pressure - Systolic", 
            "bn": "রক্ত চাপ - সিস্টোলিক", 
            "my": "သွေးခုံးအား - စတိုလစ်" 
          },
          "type": "number",
          "required": true,
          "fhirPath": "Observation.component[code=systolic].valueQuantity.value",
          "loinc": "8480-6",
          "snomed": "271649006",
          "unit": "mmHg",
          "validation": { 
            "min": 60, 
            "max": 300,
            "errorMessage": {
              "en": "Systolic BP must be between 60-300 mmHg",
              "bn": "সিস্টোলিক রক্তচাপ ৬০-৩০০ মিমিএজ-এইচ এর মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value < 90 || value > 180",
            "severity": "warning",
            "message": {
              "en": "Abnormal systolic blood pressure",
              "bn": "অস্বাভাবিক সিস্টোলিক রক্তচাপ"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "blood_pressure_diastolic",
          "label": { 
            "en": "Blood Pressure - Diastolic", 
            "bn": "রক্ত চাপ - ডায়াস্টোলিক", 
            "my": "သွေးခုံးအား - ဒိုင်းစတိုလစ်" 
          },
          "type": "number",
          "required": true,
          "fhirPath": "Observation.component[code=diastolic].valueQuantity.value",
          "loinc": "8462-4",
          "snomed": "271650006",
          "unit": "mmHg",
          "validation": { 
            "min": 30, 
            "max": 150,
            "errorMessage": {
              "en": "Diastolic BP must be between 30-150 mmHg",
              "bn": "ডায়াস্টোলিক রক্তচাপ ৩০-১৫০ মিমিএজ-এইচ এর মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value < 60 || value > 120",
            "severity": "warning",
            "message": {
              "en": "Abnormal diastolic blood pressure",
              "bn": "অস্বাভাবিক ডায়াস্টোলিক রক্তচাপ"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "heart_rate",
          "label": { 
            "en": "Heart Rate", 
            "bn": "হৃদয়ের হার", 
            "my": "နှလုခုံးနှုန်းနှုန်း" 
          },
          "type": "number",
          "required": true,
          "fhirPath": "Observation.component[code=heart-rate].valueQuantity.value",
          "loinc": "8867-4",
          "snomed": "364075005",
          "unit": "bpm",
          "validation": { 
            "min": 30, 
            "max": 250,
            "errorMessage": {
              "en": "Heart rate must be between 30-250 bpm",
              "bn": "হৃদয়ের হার ৩০-২৫০ বিপিএম এর মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value < 60 || value > 100",
            "severity": "warning",
            "message": {
              "en": "Abnormal heart rate",
              "bn": "অস্বাভাবিক হৃদয়ের হার"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "respiratory_rate",
          "label": { 
            "en": "Respiratory Rate", 
            "bn": "শ্বাসক্রিয় হার", 
            "my": "အသက်ခုံးနှုန်းနှုန်း" 
          },
          "type": "number",
          "required": true,
          "fhirPath": "Observation.component[code=respiratory-rate].valueQuantity.value",
          "loinc": "9279-1",
          "snomed": "86290005",
          "unit": "breaths/min",
          "validation": { 
            "min": 8, 
            "max": 60,
            "errorMessage": {
              "en": "Respiratory rate must be between 8-60 breaths/min",
              "bn": "শ্বাসক্রিয় হার ৮-৬০ শ্বাস/মিনিট এর মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value < 12 || value > 20",
            "severity": "warning",
            "message": {
              "en": "Abnormal respiratory rate",
              "bn": "অস্বাভাবিক শ্বাসক্রিয় হার"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "temperature",
          "label": { 
            "en": "Body Temperature", 
            "bn": "শরীরের তাপমাত্রা", 
            "my": "ခန္ဓာ့အပူခြင်" 
          },
          "type": "number",
          "required": true,
          "fhirPath": "Observation.component[code=temperature].valueQuantity.value",
          "loinc": "8310-5",
          "snomed": "276885007",
          "unit": "°C",
          "validation": { 
            "min": 25.0, 
            "max": 45.0,
            "errorMessage": {
              "en": "Temperature must be between 25-45°C",
              "bn": "তাপমাত্রা ২৫-৪৫ ডালসির মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value < 36.0 || value > 37.5",
            "severity": "warning",
            "message": {
              "en": "Abnormal body temperature",
              "bn": "অস্বাভাবিক শরীরের তাপমাত্রা"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "oxygen_saturation",
          "label": { 
            "en": "Oxygen Saturation", 
            "bn": "অক্সিজেন স্যাচুরেশন", 
            "my": "အောက်စီဂျင်စတိုရေးရှင်း" 
          },
          "type": "number",
          "required": false,
          "fhirPath": "Observation.component[code=oxygen-sat].valueQuantity.value",
          "loinc": "59408-5",
          "snomed": "442490003",
          "unit": "%",
          "validation": { 
            "min": 70, 
            "max": 100,
            "errorMessage": {
              "en": "Oxygen saturation must be between 70-100%",
              "bn": "অক্সিজেন স্যাচুরেশন ৭০-১০০% এর মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value < 95",
            "severity": "critical",
            "message": {
              "en": "Low oxygen saturation - immediate attention required",
              "bn": "কম অক্সিজেন স্যাচুরেশন - তাৎক্ষণা সহায়তা"
            },
            "trigger": "onChange"
          }
        }
      ]
    },
    {
      "sectionId": "sec-additional-vitals",
      "label": { 
        "en": "Additional Measurements", 
        "bn": "অতিরিক্ত পরিমাপ", 
        "my": "အခြားတိုင်းတိုင်းရက်စွဲများ" 
      },
      "description": {
        "en": "Additional vital signs and measurements",
        "bn": "অতিরিক্ত অত্যাবরিক চিহ্নিত্সা ও পরিমাপ"
      },
      "fields": [
        {
          "fieldId": "height",
          "label": { 
            "en": "Height", 
            "bn": "উচ্চ", 
            "my": "အရပ်အမြင့်" 
          },
          "type": "number",
          "required": false,
          "fhirPath": "Observation.component[code=height].valueQuantity.value",
          "loinc": "8302-2",
          "snomed": "50373000",
          "unit": "cm",
          "validation": { 
            "min": 30, 
            "max": 250,
            "errorMessage": {
              "en": "Height must be between 30-250 cm",
              "bn": "উচ্চ ৩০-২৫০ সেমি এর মধ্যে হতে হবে"
            }
          }
        },
        {
          "fieldId": "weight",
          "label": { 
            "en": "Weight", 
            "bn": "�জন", 
            "my": "အလေးချိန်" 
          },
          "type": "number",
          "required": false,
          "fhirPath": "Observation.component[code=weight].valueQuantity.value",
          "loinc": "29463-7",
          "snomed": "27113001",
          "unit": "kg",
          "validation": { 
            "min": 1, 
            "max": 300,
            "errorMessage": {
              "en": "Weight must be between 1-300 kg",
              "bn": "ওজন ১-৩০০ কেজি এর মধ্যে হতে হবে"
            }
          }
        },
        {
          "fieldId": "bmi_calculated",
          "label": { 
            "en": "BMI (Calculated)", 
            "bn": "বিএমআই (গণনা)", 
            "my": "ဘီအိုင်မိုင်းအင်ဒက် (တွက်ခ်စလ်)" 
          },
          "type": "calculated",
          "required": false,
          "fhirPath": "Observation.component[code=bmi].valueQuantity.value",
          "loinc": "39156-5",
          "snomed": "60621009",
          "unit": "kg/m²",
          "calculatedExpression": "weight / ((height/100) * (height/100))",
          "conditionalDisplay": {
            "fieldId": "height",
            "operator": "exists",
            "value": true
          },
          "alertCondition": {
            "condition": "value < 18.5 || value > 30",
            "severity": "warning",
            "message": {
              "en": "Abnormal BMI - nutritional assessment recommended",
              "bn": "অস্বাভাবিক বিএমআই - পুষ্টিকার মূল্যায়ন সুপারিশ করা হয়"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "blood_glucose",
          "label": { 
            "en": "Blood Glucose", 
            "bn": "রক্তে গ্লুকোজ", 
            "my": "သွေးခုံးအားဂလူးကိုစ်" 
          },
          "type": "number",
          "required": false,
          "fhirPath": "Observation.component[code=glucose].valueQuantity.value",
          "loinc": "2345-7",
          "snomed": "100313100",
          "unit": "mmol/L",
          "validation": { 
            "min": 1.0, 
            "max": 40.0,
            "errorMessage": {
              "en": "Blood glucose must be between 1-40 mmol/L",
              "bn": "রক্তে গ্লুকোজ ১-৪০ মিমোল/এল এর মধ্যে হতে হবে"
            }
          },
          "alertCondition": {
            "condition": "value > 11.1",
            "severity": "warning",
            "message": {
              "en": "High blood glucose - diabetes screening recommended",
              "bn": "উচ্চ রক্ত গ্লুকোজ - ডায়াবিটিস স্ক্রিনিং সুপারিশ করা হয়"
            },
            "trigger": "onChange"
          }
        }
      ]
    },
    {
      "sectionId": "sec-pain-assessment",
      "label": { 
        "en": "Pain Assessment", 
        "bn": "ব্যথা মূল্যায়ন", 
        "my": "နာကျင်စစ်ဆိုင်း" 
      },
      "description": {
        "en": "Pain scale and assessment",
        "bn": "ব্যথা স্কেল ও মূল্যায়ন"
      },
      "fields": [
        {
          "fieldId": "pain_present",
          "label": { 
            "en": "Is patient experiencing pain?", 
            "bn": "রোগী কি ব্যথা অনুভব করছেন?", 
            "my": "လူနာသည်နာကျင်ခံစာပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီးပြီসပြমসပ়মসক়মস" 
          },
          "type": "radio",
          "required": true,
          "fhirPath": "Observation.component[code=pain-present].valueBoolean",
          "options": [
            { 
              "value": "yes", 
              "label": { 
                "en": "Yes", 
                "bn": "হ্যাঁ", 
                "my": "ဟုတ်" 
              } 
            },
            { 
              "value": "no", 
              "label": { 
                "en": "No", 
                "bn": "না", 
                "my": "မဟုတ်" 
              } 
            }
          ]
        },
        {
          "fieldId": "pain_scale",
          "label": { 
            "en": "Pain Scale (0-10)", 
            "bn": "ব্যথা স্কেল (০-১০)", 
            "my": "နာကျင်စစ်ဆိုင်း (၀-၁၀)" 
          },
          "type": "range",
          "required": false,
          "fhirPath": "Observation.component[code=pain-scale].valueQuantity.value",
          "loinc": "72514-3",
          "snomed": "22253000",
          "unit": "score",
          "validation": { 
            "min": 0, 
            "max": 10 
          },
          "conditionalDisplay": {
            "fieldId": "pain_present",
            "operator": "eq",
            "value": "yes"
          },
          "alertCondition": {
            "condition": "value >= 7",
            "severity": "warning",
            "message": {
              "en": "Severe pain - immediate assessment required",
              "bn": "তীব্র ব্যথা - তাৎক্ষণা মূল্যায়ন আবশ্যক"
            },
            "trigger": "onChange"
          }
        },
        {
          "fieldId": "pain_location",
          "label": { 
            "en": "Pain Location", 
            "bn": "ব্যথার স্থান", 
            "my": "နာကျင်တည်နေရာ" 
          },
          "type": "textarea",
          "required": false,
          "fhirPath": "Observation.component[code=pain-location].valueString",
          "conditionalDisplay": {
            "fieldId": "pain_present",
            "operator": "eq",
            "value": "yes"
          }
        }
      ]
    },
    {
      "sectionId": "sec-clinician-notes",
      "label": { 
        "en": "Clinician Notes", 
        "bn": "চিকিৎসক নোট", 
        "my": "ဆရားမှုတ်မ်းတင်သူမှတ်တမ်း" 
      },
      "description": {
        "en": "Clinical observations and notes",
        "bn": "ক্লিনিকাল পর্যবেক্ষা ও নোট"
      },
      "fields": [
        {
          "fieldId": "general_appearance",
          "label": { 
            "en": "General Appearance", 
            "bn": "সাধারণ চেহারা", 
