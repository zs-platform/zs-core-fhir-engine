        {
          "fieldId": "consent_date_time",
          "label": { 
            "en": "Consent Date & Time", 
            "bn": "সম্মতি তারিখ ও সময়", 
            "my": "သဘောတူညီမှုရက်စွဲ" 
          },
          "type": "datetime",
          "required": true,
          "fhirPath": "Patient.extension[consent-datetime].valueDateTime",
          "defaultValue": "${currentDateTime}"
        }
      ]
