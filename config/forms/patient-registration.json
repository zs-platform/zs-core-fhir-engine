  ],
  "validationRules": [
    {
      "ruleId": "age_validation",
      "description": {
        "en": "Validate age consistency",
        "bn": "বয়সের সামঞ্জস্যতা যাচাই"
      },
      "condition": {
        "fieldId": "date_of_birth",
        "operator": "exists",
        "value": true
      },
      "expression": "ageBetween(date_of_birth, 0, 150)",
      "errorMessage": {
        "en": "Age must be between 0 and 150 years",
        "bn": "বয়স ০ থেকে ১৫০ বছরের মধ্যে হতে হবে"
      },
      "severity": "error"
    },
    {
      "ruleId": "contact_info_validation",
      "description": {
        "en": "At least one contact method required",
        "bn": "অন্তত একটি যোগাযোগ পদ্ধতি আবশ্যক"
      },
      "condition": {
        "logicalOperator": "or",
        "conditions": [
          { "fieldId": "phone_number", "operator": "exists", "value": true },
          { "fieldId": "email_address", "operator": "exists", "value": true }
        ]
      },
      "expression": "phone_number || email_address",
      "errorMessage": {
        "en": "Please provide either phone number or email address",
        "bn": "অনুগ্রহণ করুন ফোন নম্বর বা ইমেল ঠিকানা"
      },
      "severity": "warning"
    }
  ],
  "workflows": [
    {
      "workflowId": "patient_registration_complete",
      "name": {
        "en": "Complete Patient Registration",
        "bn": "সম্পূর্ণ রোগী নিবন্ধন"
      },
      "trigger": "onSubmit",
      "actions": [
        {
          "action": "create_patient",
          "target": "fhir-server",
          "parameters": {
            "resource": "Patient",
            "profile": "zs-patient-v2"
          }
        },
        {
          "action": "generate_medical_record",
          "target": "emr-system",
          "parameters": {
            "record_type": "initial"
          }
        },
        {
          "action": "assign_unique_id",
          "target": "id-generator",
          "parameters": {
            "type": "UHID"
          }
        }
      ]
    }
  ]
}
