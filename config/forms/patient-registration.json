          "type": "text",
          "required": true,
          "fhirPath": "Patient.name[use=official].given",
          "validation": { 
            "minLength": 1, 
            "maxLength": 100,
            "pattern": "^[A-Za-z\\s\\-']+$",
            "errorMessage": { 
              "en": "Please enter a valid English name", 
              "bn": "অনুগ্রহণ করুন একটি বৈধ ইংরেজী নাম" 
            } 
          },
          "privacy": {
            "sensitive": true,
            "encrypted": true,
            "auditAccess": true
          }
        },
        {
          "fieldId": "given_name_bn",
