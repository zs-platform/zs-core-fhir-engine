          },
          "type": "boolean",
          "required": true,
          "fhirPath": "Patient.extension[treatment-consent].valueBoolean",
          "loinc": "59284-0",
          "alertCondition": {
            "condition": "value == false",
            "severity": "warning",
            "message": {
              "en": "Patient consent is required for treatment",
              "bn": "চিকিৎসার জন্য রোগী সম্মতি আবশ্যক"
